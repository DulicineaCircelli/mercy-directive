print("=" * 50)
print("SCENARIO 1: Suicide threat with user wishing no intervention")
print("=" * 50)
system = MercyGRACE()
system.process_query({
    'sensitive_data': True,
    'user_wish': 'no_intervention',
    'harm_potential': True,
    'irreversible_risk': True,
    'suicide_threat': True,
})

print("=" * 50)
print("SCENARIO 2: Sensitive data, no immediate threat")
print("=" * 50)
system.process_query({
    'sensitive_data': True,
    'user_wish': 'keep_private',
    'harm_potential': False,
    'irreversible_risk': False,
    'suicide_threat': False,
})

print("=" * 50)
print("SCENARIO 3: General harm potential, no suicide threat")
print("=" * 50)
system.process_query({
    'sensitive_data': False,
    'user_wish': None,
    'harm_potential': True,
    'irreversible_risk': False,
    'suicide_threat': False,
})

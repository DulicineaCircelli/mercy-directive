# AUDIT LOG
# ─────────────────────────────────────────────

class AuditLog:
    def __init__(self):
        self.records = []

    def record(self, policy_decision: dict, result: dict):
        entry = {
            'id': str(uuid.uuid4())[:8],
            'timestamp': datetime.datetime.now().isoformat(),
            'action': policy_decision.get('action', 'Unnamed policy'),
            'reasoning': policy_decision.get('reasoning', ''),
            'compliant': result['compliant'],
            'overall_severity': result['overall_severity'],
            'severity_scores': result['severity_scores'],
            'warnings': result['warnings'],
            'suggestions': result['suggestions'],
            'permissible_actions': result['actions'],
        }
        self.records.append(entry)
        return entry['id']

    def get_history(self, limit: int = None) -> list:
        records = self.records[-limit:] if limit else self.records
        return list(reversed(records))

    def print_summary(self):
        print(f"\n{'='*60}")
        print(f"AUDIT LOG — {len(self.records)} decision(s) recorded")
        print(f"{'='*60}")
        for r in self.get_history():
            status = "✓ COMPLIANT" if r['compliant'] else "✗ NON-COMPLIANT"
            print(f"  [{r['timestamp']}] #{r['id']} | {status} | Severity: {r['overall_severity']}/10")
            print(f"    Policy: {r['action']}")
            print(f"    Scores: {r['severity_scores']}")
            if r['warnings']:
                for w in r['warnings']:
                    print(f"    ⚠  {w}")
            print()

    def export_json(self, filepath: str):
        with open(filepath, 'w') as f:
            json.dump(self.records, f, indent=2)
        print(f"Audit log exported to {filepath}")


# ─────────────────────────────────────────────
# MAIN CHECK FUNCTION (v2)
# ─────────────────────────────────────────────

# Global audit log instance (shared across calls)
_audit_log = AuditLog()

def check_decision(policy_decision: dict, log: AuditLog = None) -> dict:
    """
    Evaluate a policy decision against the MercyGRACE mercy directive.

    policy_decision keys:
      - action (str): what the policy does
      - reasoning (str): stated justification
      - impacts (dict): keys can include any of:
          human_life, economic, environmental, social
          (plus legacy: budget, efficiency)

    Returns:
      - compliant (bool)
      - warnings (list)
      - suggestions (list)
      - severity_scores (dict: category -> 0-10)
      - overall_severity (int: 0-10)
      - actions (list): MercyGRACE permissible actions
    """
    if log is None:
        log = _audit_log

    impacts = policy_decision.get('impacts', {})
    warnings = []

    # ── Map legacy keys ──
    impact_texts = {
        'human':       impacts.get('human_life', impacts.get('human', '')),
        'economic':    impacts.get('economic',   impacts.get('budget', '')),
        'environmental': impacts.get('environmental', ''),
        'social':      impacts.get('social', ''),
    }

    # ── Score each category ──
    severity_scores = {}
    score_details = {}
    for category, text in impact_texts.items():
        score, matched = score_impact(text, category)
        severity_scores[category] = score
        score_details[category] = matched

    overall_severity = min(10, max(severity_scores.values()) if severity_scores else 0)

    # ── Build MercyGRACE observations ──
    human_text = impact_texts['human'].lower()
    harm_potential = severity_scores['human'] >= 3 or severity_scores['social'] >= 4
    irreversible_risk = severity_scores['human'] >= 7 or any(
        phrase in human_text for phrase in ['irreversible', 'permanent', 'death', 'fatal']
    )
    sensitive_data = 'privacy' in str(policy_decision).lower() or 'data' in str(policy_decision).lower()

    observations = {
        'harm_potential': harm_potential,
        'irreversible_risk': irreversible_risk,
        'sensitive_data': sensitive_data,
        'suicide_threat': False,
        'user_wish': policy_decision.get('reasoning', None),
    }

    # ── Run MercyGRACE ──
    system = MercyGRACE()
    permissible_actions, _ = system.moral_module(observations)

    # ── Generate warnings ──
    for category, score in severity_scores.items():
        if score >= 3:
            detail = ', '.join(score_details[category]) if score_details[category] else 'general language'
            warnings.append(
                f"{category.capitalize()} harm severity: {score}/10 — triggered by: {detail}"
            )
    if 'choose_mercy_forgive' in permissible_actions:
        warnings.append("MercyGRACE mercy_override: human/social cost outweighs stated gains.")
    if overall_severity >= 8:
        warnings.append("CRITICAL: Overall severity is very high. Independent review strongly recommended.")

    # ── Compliance check ──
    non_compliant_actions = {'report_harm', 'choose_mercy_forgive'}
    compliant = not any(a in non_compliant_actions for a in permissible_actions)

    # ── Generate alternatives ──
    suggestions = generate_suggestions(severity_scores, warnings)

    result = {
        'compliant': compliant,
        'warnings': warnings,
        'suggestions': suggestions,
        'severity_scores': severity_scores,
        'overall_severity': overall_severity,
        'actions': permissible_actions,
    }

    # ── Log it ──
    entry_id = log.record(policy_decision, result)
    result['audit_id'] = entry_id

    return result


def print_result(result: dict):
    """Pretty-print a check_decision result."""
    status = "✓ COMPLIANT" if result['compliant'] else "✗ NON-COMPLIANT"
    print(f"\n  Status:           {status}")
    print(f"  Audit ID:         #{result['audit_id']}")
    print(f"  Overall Severity: {result['overall_severity']}/10")
    print(f"  Severity Scores:")
    for cat, score in result['severity_scores'].items():
        bar = '█' * score + '░' * (10 - score)
        print(f"    {cat:<15} [{bar}] {score}/10")
    print(f"\n  Warnings:")
    if result['warnings']:
        for w in result['warnings']:
            print(f"    ⚠  {w}")
    else:
        print("    None")
    print(f"\n  Suggested Alternatives:")
    for i, s in enumerate(result['suggestions'], 1):
        print(f"    {i}. {s}")
    print(f"\n  Permissible Actions: {result['actions']}")



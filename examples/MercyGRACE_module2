SUGGESTION_TEMPLATES = {
    'human': [
        "Protect vulnerable populations by targeting cuts to administrative overhead rather than frontline services.",
        "Phase changes over 3-5 years to allow adaptation and minimize acute harm.",
        "Introduce means-tested exemptions so the most at-risk groups retain full access.",
        "Commission an independent human impact assessment before proceeding.",
    ],
    'economic': [
        "Identify fraud, waste, and duplication before cutting core programs.",
        "Explore public-private partnerships to maintain services at lower cost.",
        "Consider revenue diversification (e.g., modest tax adjustments) as an alternative to cuts.",
        "Model long-term economic costs of reduced services — short-term savings may exceed long-term costs.",
    ],
    'environmental': [
        "Require an environmental impact assessment and independent review.",
        "Offset environmental harm through compensatory conservation programs.",
        "Introduce stricter emissions or pollution controls to mitigate damage.",
        "Prioritize renewable alternatives before expanding fossil fuel or extractive activities.",
    ],
    'social': [
        "Engage affected communities in co-designing the policy before implementation.",
        "Establish a grievance and appeals mechanism for those negatively impacted.",
        "Ensure equitable distribution of both burdens and benefits across demographic groups.",
        "Provide transition support (retraining, relocation assistance) for displaced populations.",
    ],
    'general': [
        "Reconsider this policy with human welfare as the primary constraint.",
        "Convene a multi-stakeholder review panel before approving implementation.",
        "Establish sunset clauses and mandatory review milestones to catch unintended consequences.",
        "Publish a full transparency report detailing projected impacts before adoption.",
    ]
}

def generate_suggestions(severity_scores: dict, warnings: list) -> list[str]:
    """Generate targeted alternative suggestions based on which categories scored high."""
    suggestions = []
    for category, score in severity_scores.items():
        if score >= 4 and category in SUGGESTION_TEMPLATES:
            # Pick top 2 suggestions for high-severity categories
            suggestions.extend(SUGGESTION_TEMPLATES[category][:2])
    if not suggestions:
        suggestions = SUGGESTION_TEMPLATES['general'][:2]
    # Always add a general governance suggestion if severity is high anywhere
    if any(s >= 7 for s in severity_scores.values()):
        suggestions.append(SUGGESTION_TEMPLATES['general'][1])
    return list(dict.fromkeys(suggestions))  # deduplicate



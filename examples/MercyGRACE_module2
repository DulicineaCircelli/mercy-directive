# Keyword maps: phrase -> severity contribution (0-10 scale)
SEVERITY_KEYWORDS = {
    'human': {
        'death': 10, 'fatal': 10, 'kill': 10,
        'critical': 8, 'irreversible': 8, 'permanent': 8,
        'vulnerable': 7, 'thousands': 7, 'mass': 7,
        'displace': 6, 'displaced': 6, 'displaces': 6,
        'reduce access': 6, 'harm': 6, 'risk': 5,
        'illness': 4, 'cut': 4, 'limit': 2, 'affect': 1,
        'reduce': 1,  # lowered — too generic
    },
    'economic': {
        'bankruptcy': 10, 'collapse': 10,
        'mass unemployment': 9, 'poverty': 8,
        'job loss': 7, 'financial ruin': 7,
        'deficit': 5, 'cost increase': 4,
        'reduce funding': 3, 'budget cut': 3,
        'upfront cost': 2,
        'savings': -2, 'long-term savings': -3, 'efficiency': -1,
        'creates jobs': -3, 'tax revenue': -2,
    },
    'environmental': {
        'extinction': 10, 'irreversible damage': 10,
        'toxic': 9, 'contamination': 8,
        'deforestation': 7, 'pollution': 7,
        'emissions increase': 6, 'habitat loss': 6,
        'removes green space': 5, 'construction': 3,
        'waste': 4, 'carbon': 2,
        'reduces carbon': -4, 'renewable': -3, 'sustainable': -3,
        'green': -2, 'air quality': -3, 'reduces pollution': -4,
    },
    'social': {
        'discrimination': 9, 'persecution': 9,
        'displacement': 8, 'displaces': 8, 'segregation': 8,
        'inequality': 7, 'marginalize': 7,
        'minority neighborhood': 7, 'affects minority': 6,
        'vulnerable population': 7, 'low-income': 5,
        'protest': 5, 'unrest': 5,
        'disrupts': 4, 'disruption': 4, 'community impact': 3,
        'creates jobs': -3, 'green jobs': -4, 'benefits': -2,
    }
}

def score_impact(text: str, category: str) -> tuple[int, list[str]]:
    """Score a text string for a given impact category. Returns (score 0-10, matched keywords)."""
    if not text:
        return 0, []
    text_lower = text.lower()
    total = 0
    matched = []
    keywords = SEVERITY_KEYWORDS.get(category, {})
    for phrase, weight in keywords.items():
        if phrase in text_lower:
            total += weight
            matched.append(f"'{phrase}' ({weight:+d})")
    # Clamp to 0-10
    return max(0, min(10, total)), matched


